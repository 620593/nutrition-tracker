# .env.example
# This file serves as a template for the required environment variables.
# Copy this file to .env and fill in the actual values before running the backend.
# It includes keys for Supabase, OpenAI/Gemini API access, and app configuration.
# Never commit your actual .env file to version control.

SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
APP_SECRET_KEY=your_app_secret_key
