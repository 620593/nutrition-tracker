# .env.example
# This file serves as a template for the required environment variables.
# Copy this file to .env and fill in the actual values before running the backend.
# It includes keys for Supabase, Groq LLM, USDA Food API, and HuggingFace.
# Never commit your actual .env file to version control.

SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
GROQ_API_KEY=your_groq_api_key
USDA_API_KEY=your_usda_api_key
HF_TOKEN=your_huggingface_token
